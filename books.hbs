<style>
  body {
    background-color: #ffe8c2;
    margin: 0;
    padding: 20px;
    font-family: "Segoe UI", Tahoma, Geneva, Verdana, sans-serif;
    display: flex;
    justify-content: center;
    align-items: flex-start;
    min-height: 100vh;
  }

  .main-container {
    background: #ffd79a;
    padding: 30px;
    border-radius: 20px;
    box-shadow: 0 10px 30px rgba(0,0,0,0.15);
    width: 95%;
    max-width: 950px;
    margin: 20px auto;
  }

  .btn-orange {
    background-color: #ff8c42;
    border: none;
    border-radius: 10px;
    padding: 10px 20px;
    cursor: pointer;
    display: inline-block;
    text-decoration: none;
    margin-bottom: 20px;
    color: white !important;
    font-weight: bold;
    text-transform: uppercase;
    font-size: 0.9rem;
  }

  .btn-orange:hover {
    background-color: #ff6f00;
  }

  table {
    width: 100%;
    border-collapse: collapse;
    margin-top: 10px;
    background: white;
    border-radius: 20px;
    overflow: hidden;
  }

  th, td {
    padding: 12px;
    text-align: center;
  }

  th {
    background-color: #ffb347;
    color: white;
    text-transform: uppercase;
    font-size: 0.85rem;
  }

  td {
    color: #444;
  }

  .edit-btn {
    padding: 6px 12px;
    font-size: 0.8rem;
    margin-bottom: 0;
  }

  .form-group {
    margin-bottom: 15px;
  }

  .form-group label {
    display: block;
    font-weight: bold;
    margin-bottom: 5px;
    color: #ff6f00;
  }

  .form-group input {
    width: 100%;
    padding: 12px;
    border: 2px solid #ffcc80;
    border-radius: 10px;
    box-sizing: border-box;
    outline: none;
  }

  .form-group input:focus {
    border-color: #ff8c42;
  }
</style>

{{#if mode}}
<div class="main-container">
  <h2>{{pageTitle}}</h2>

  <form action="{{action}}" method="POST">

    <div class="form-group">
      <label>Title:</label>
      <input
        type="text"
        name="title"
        value="{{item.title}}"
        placeholder="Enter title..."
        required
      />
    </div>

    <div class="form-group">
      <label>Author:</label>
      <input
        type="text"
        name="author"
        value="{{item.author}}"
        placeholder="Enter author..."
        required
      />
    </div>

    <div class="form-group">
      <label>Genre:</label>
      <input
        type="text"
        name="genre"
        value="{{item.genre}}"
        placeholder="Enter genre..."
      />
    </div>

    <div class="form-group">
      <label>Pages:</label>
      <input
        type="number"
        name="pages"
        value="{{item.pages}}"
        placeholder="Enter pages..."
      />
    </div>

    <div class="form-group">
      <label>Price:</label>
      <input
        type="number"
        step="0.01"
        name="price"
        value="{{item.price}}"
        placeholder="Enter price..."
      />
    </div>

    <button type="submit" class="btn-orange" style="width:100%;">SAVE</button>
    <a href="/books" class="btn-orange" style="width:100%; text-align:center;">CANCEL</a>

  </form>
</div>

{{else}}

<div class="main-container">

  <a href="/" class="btn-orange">BACK</a>

  <table>
    <thead>
      <tr>
        <th>ID</th>
        <th>Title</th>
        <th>Author</th>
        <th>Genre</th>
        <th>Pages</th>
        <th>Price</th>
        <th colspan="2">Actions</th>
      </tr>
    </thead>

    <tbody>
      {{#each books}}
      <tr>
        <td>{{this.id}}</td>
        <td>{{this.title}}</td>
        <td>{{this.author}}</td>
        <td>{{this.genre}}</td>
        <td>{{this.pages}}</td>
        <td>{{this.price}}</td>

        <td>
          <a href="/books/edit/{{this.id}}" class="btn-orange edit-btn">
            EDIT
          </a>
        </td>

        <td>
          <a
            href="/books/delete/{{this.id}}"
            class="btn-orange edit-btn"
            onclick="return confirm('Delete this book?')"
          >
            DELETE
          </a>
        </td>
      </tr>
      {{/each}}
    </tbody>
  </table>

  <a href="/books/createBook" class="btn-orange">Create Book</a>

</div>
{{/if}}