<style>
    body { 
        background: #0b0e14; 
        color: white; 
        font-family: 'Segoe UI', Roboto, sans-serif; 
        margin: 0; 
        padding: 40px;
        display: flex;
        justify-content: center;
    }

    .container {
        max-width: 1100px;
        width: 100%;
    }

   
    .nav-bar {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 40px;
    }

    .btn-home {
        background: rgba(255, 255, 255, 0.05);
        color: #888;
        padding: 10px 20px;
        border-radius: 12px;
        text-decoration: none;
        border: 1px solid #333;
        transition: 0.3s;
        font-size: 14px;
        backdrop-filter: blur(5px);
    }

    .btn-home:hover {
        color: white;
        border-color: #007bbd;
        background: rgba(0, 123, 189, 0.1);
    }

    h1 {
        font-size: 2.5rem;
        margin: 0;
        letter-spacing: -1px;
        background: linear-gradient(to right, #fff, #1DB954);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
    }

  
    .btn-create {
        background: #1DB954;
        color: white;
        padding: 12px 25px;
        border-radius: 50px;
        text-decoration: none;
        font-weight: bold;
        transition: 0.3s;
        box-shadow: 0 4px 15px rgba(29, 185, 84, 0.3);
    }

    .btn-create:hover {
        background: #1ed760;
        transform: scale(1.05);
    }

  
    .table-container {
        background: #1a1d24;
        border-radius: 24px;
        border: 1px solid #333;
        overflow: hidden;
        box-shadow: 0 20px 50px rgba(0,0,0,0.5);
    }

    table {
        width: 100%;
        border-collapse: collapse;
        text-align: left;
    }

    th {
        padding: 20px;
        background: rgba(0,0,0,0.2);
        color: #1DB954;
        text-transform: uppercase;
        font-size: 12px;
        letter-spacing: 1px;
    }

    td {
        padding: 20px;
        border-bottom: 1px solid #242832;
        font-size: 15px;
    }

    tr:last-child td {
        border-bottom: none;
    }

    tr:hover td {
        background: rgba(255, 255, 255, 0.02);
    }

   
    .action-btn {
        padding: 8px 16px;
        border-radius: 8px;
        text-decoration: none;
        font-weight: bold;
        font-size: 13px;
        transition: 0.2s;
        margin-right: 5px;
    }

    .edit-btn {
        color: #4facfe;
        border: 1px solid #4facfe;
    }

    .edit-btn:hover {
        background: #4facfe;
        color: white;
    }

    .delete-btn {
        color: #ff4b2b;
        border: 1px solid #ff4b2b;
    }

    .delete-btn:hover {
        background: #ff4b2b;
        color: white;
    }

    .duration-tag {
        font-family: 'Courier New', Courier, monospace;
        color: #888;
        background: #000;
        padding: 4px 8px;
        border-radius: 5px;
    }
</style>
//.

<div class="container">
    <div class="nav-bar">
        <a href="/" class="btn-home">GO BACK</a>
        <h1>SPOTIFY</h1>
        <a href="/spotify/create" class="btn-create">+ ADD TRACK</a>
    </div>

    <div class="table-container">
        <table>
            <thead>
                <tr>
                    <th>Title</th>
                    <th>Artist</th>
                    <th>Genre</th>
                    <th>Duration</th>
                    <th style="text-align: right;">Actions</th>
                </tr>
            </thead>
            <tbody>
                {{#each tracks}}
                <tr>
                    <td style="font-weight: bold; font-size: 1.1rem;">{{this.title}}</td>
                    <td style="color: #bbb;">{{this.artist}}</td>
                    <td>
                        <span style="color: #1DB954; font-size: 13px;">●</span> 
                        {{this.genre}}
                    </td>
                    <td><span class="duration-tag">{{this.duration}}</span></td>
                    <td style="text-align: right;">
                        <a href="/spotify/update/{{this.id}}" class="action-btn edit-btn">Edit</a>
                        <a href="/spotify/delete/{{this.id}}" class="action-btn delete-btn" onclick="return confirm('Видалити?')">Delete</a>
                    </td>
                </tr>
                {{/each}}
                {{#unless tracks}}
                <tr>
                    <td colspan="5" style="text-align: center; padding: 50px; color: #555;">
                        Список порожній. Час додати трохи музики!
                    </td>
                </tr>
                {{/unless}}
            </tbody>
        </table>
    </div>
    
    <p style="text-align: right; color: #444; margin-top: 20px; font-size: 12px;">
        
    </p>
</div>