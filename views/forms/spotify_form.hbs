<style>
    body { background: #0b0e14; color: white; font-family: 'Segoe UI', sans-serif; margin: 0; padding: 40px; display: flex; justify-content: center; }
    .container { max-width: 600px; width: 100%; }
    .nav-bar { display: flex; justify-content: space-between; align-items: center; margin-bottom: 40px; }
    .btn-back { background: rgba(255,255,255,0.05); color: #888; padding: 10px 20px; border-radius: 12px; text-decoration: none; border: 1px solid #333; transition: 0.3s; }
    .btn-back:hover { color: white; border-color: #1DB954; }
    h1 { font-size: 2.2rem; margin: 0; background: linear-gradient(to right, #fff, #1DB954); -webkit-background-clip: text; -webkit-text-fill-color: transparent; }
    .form-box { background: #1a1d24; border-radius: 24px; border: 1px solid #333; padding: 30px; box-shadow: 0 20px 50px rgba(0,0,0,0.5); }
    .group { margin-bottom: 20px; }
    label { display: block; color: #1DB954; text-transform: uppercase; font-size: 11px; letter-spacing: 1.5px; margin-bottom: 10px; font-weight: bold; }
    input { width: 100%; padding: 15px; background: #0b0e14; border: 1px solid #333; border-radius: 12px; color: white; font-size: 16px; box-sizing: border-box; transition: 0.3s; }
    input:focus { outline: none; border-color: #1DB954; background: #12161f; }
    
    /* Прибираємо стрілочки (spinners) для поля number */
    input::-webkit-outer-spin-button,
    input::-webkit-inner-spin-button {
        -webkit-appearance: none;
        margin: 0;
    }
    input[type=number] {
        -moz-appearance: textfield;
    }

    .btn-save { width: 100%; background: #1DB954; color: white; padding: 18px; border: none; border-radius: 50px; font-size: 16px; font-weight: bold; cursor: pointer; transition: 0.3s; margin-top: 10px; box-shadow: 0 10px 20px rgba(29, 185, 84, 0.2); }
    .btn-save:hover { background: #1ed760; transform: scale(1.02); }
</style>

<div class="container">
    <div class="nav-bar">
        <a href="/spotify" class="btn-back">← BACK</a>
        <h1>{{title}}</h1>
    </div>

    <div class="form-box">
        <form action="{{action}}" method="POST">
            <div class="group">
                <label>Track Title</label>
                <input type="text" name="title" value="{{item.title}}" required>
            </div>
            <div class="group">
                <label>Artist</label>
                <input type="text" name="artist" value="{{item.artist}}" required>
            </div>
            <div class="group">
                <label>Genre</label>
                <input type="text" name="genre" value="{{item.genre}}" required>
            </div>
            <div class="group">
                <label>Duration (sec)</label>
                <input type="number" name="duration" value="{{item.duration}}" required>
            </div>
            <button type="submit" class="btn-save">
                {{#if isUpdate}}SAVE CHANGES{{else}}ADD TRACK{{/if}}
            </button>
        </form>
    </div>
</div>