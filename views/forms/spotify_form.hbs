<style>
    body {
        background: #0b0e14;
        color: white;
        font-family: 'Segoe UI', Roboto, sans-serif;
        margin: 0;
        display: flex;
        justify-content: center;
        align-items: center;
        min-height: 100vh;
    }

    .form-container {
        background: #1a1d24;
        padding: 40px;
        border-radius: 24px;
        border: 1px solid #333;
        box-shadow: 0 20px 50px rgba(0,0,0,0.6);
        width: 100%;
        max-width: 800px;
    }

    h2 { color: #1DB954; text-align: center; margin-bottom: 30px; font-size: 1.8rem; }

    .fields-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 0 30px;
    }

    label { font-size: 11px; color: #888; text-transform: uppercase; letter-spacing: 1.5px; margin-bottom: 6px; display: block; }

    input {
        width: 100%; padding: 14px; margin-bottom: 6px;
        background: #242832; border: 2px solid transparent;
        color: white; border-radius: 12px; box-sizing: border-box;
        font-size: 1rem; transition: 0.3s;
    }

    input[type="number"]::-webkit-inner-spin-button,
    input[type="number"]::-webkit-outer-spin-button { -webkit-appearance: none; margin: 0; }
    input[type="number"] { -moz-appearance: textfield; }

    input:focus { border-color: #007bbd; outline: none; }
    input.input-error { border-color: #e74c3c; }

    .field-error { font-size: 11px; color: #e74c3c; margin-bottom: 14px; padding-left: 4px; }
    .field-error::before { content: '⚠ '; }

    .form-footer {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 0 30px;
        align-items: center;
        margin-top: 10px;
    }

    .btn-save {
        width: 100%; padding: 14px; background: #1DB954;
        color: black; border: none; border-radius: 12px;
        font-weight: bold; font-size: 1rem; cursor: pointer;
        transition: 0.2s;
    }
    .btn-save:hover { background: #17a349; }

    .btn-cancel {
        width: 100%; padding: 14px; background: #000;
        color: #fff; border: 2px solid #fff; border-radius: 12px;
        font-weight: bold; font-size: 1rem; cursor: pointer;
        text-decoration: none; display: block; text-align: center;
        box-sizing: border-box; transition: 0.2s;
    }
    .btn-cancel:hover { background: #111; }
</style>

<div class="form-container">
    <h2>{{#if isUpdate}}Edit Track{{else}}New Track{{/if}}</h2>

    <form action="{{#if isUpdate}}/spotify/update/{{item.id}}{{else}}/spotify/create{{/if}}" method="POST">
        <div class="fields-grid">

            <div>
                <label>Title</label>
                <input type="text" name="title" value="{{item.title}}" class="{{#if fieldErrors.title}}input-error{{/if}}">
                {{#if fieldErrors.title}}<div class="field-error">{{fieldErrors.title}}</div>{{/if}}
            </div>

            <div>
                <label>Artist</label>
                <input type="text" name="artist" value="{{item.artist}}" class="{{#if fieldErrors.artist}}input-error{{/if}}">
                {{#if fieldErrors.artist}}<div class="field-error">{{fieldErrors.artist}}</div>{{/if}}
            </div>

            <div>
                <label>Genre</label>
                <input type="text" name="genre" value="{{item.genre}}" class="{{#if fieldErrors.genre}}input-error{{/if}}">
                {{#if fieldErrors.genre}}<div class="field-error">{{fieldErrors.genre}}</div>{{/if}}
            </div>

            <div>
                <label>Duration (сек)</label>
                <input type="number" name="duration" value="{{item.duration}}" class="{{#if fieldErrors.duration}}input-error{{/if}}">
                {{#if fieldErrors.duration}}<div class="field-error">{{fieldErrors.duration}}</div>{{/if}}
            </div>

        </div>

        <div class="form-footer">
            <button type="submit" class="btn-save">Save</button>
            <a href="/spotify" class="btn-cancel">Cancel</a>
        </div>
    </form>
</div>