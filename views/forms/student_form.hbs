<form method="POST" action="{{action}}">
    <fieldset>
        <label>
            First name
            <input
                    name="firstName"
                    placeholder="First name"
                    autocomplete="given-name"
            />
        </label>
        <label>
            Last name
            <input
                    name="lastName"
                    placeholder="Last name"
                    autocomplete="family-name"
            />
        </label>
    </fieldset>

    <input
            type="submit"
            value="Confirm"
    />
</form>