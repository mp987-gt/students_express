<button  
    style="background-color: rgb(242, 130, 208)">
    <a style="color:#ffffff" href="/sloniki">
        GO BACK
    </a>
</button>

<form action="/sloniki/delete" method="POST">
  <div class="form-group">
    <label>Username</label>
    <input type="text" name="username" value="{{username}}">
    
    {{#if errors.username}}
      <p style="color:#ff0000">{{errors.username}}</p>
    {{/if}}
  </div>

  <div class="form-group">
    <label>Password:</label>
    <input type="password" name="password">
    
    {{#if errors.password}}
      <p style="color:#ff0000">{{errors.password}}</p>
    {{/if}}
  </div>

  {{#if errors.general}}
    <div style="color: darkred; font-weight: bold;">{{errors.general}}</div>
  {{/if}}

  <button type="submit">Delete</button>
</form>