<!DOCTYPE html>
<html lang="uk">
<head>
    <meta charset="UTF-8">
    <title>Estate | Форма</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    <style>
        body {
            font-family: 'Inter', sans-serif;
            background-color: #f1f5f9;
            display: flex;
            justify-content: center;
            align-items: center;
            min-height: 100vh;
            margin: 0;
        }






        .form-card {
            background: white;
            width: 100%;
            max-width: 500px;
            padding: 40px;
            border-radius: 24px;
            box-shadow: 0 20px 25px -5px rgba(0,0,0,0.1);
        }

        h2 { margin: 0 0 30px 0; font-size: 24px; font-weight: 700; color: #0f172a; text-align: center; }

        .form-group { margin-bottom: 20px; }
        label { display: block; font-size: 13px; font-weight: 600; color: #64748b; margin-bottom: 8px; text-transform: uppercase; }

        input, textarea {
            width: 100%;
            padding: 12px 16px;
            border: 2px solid #f1f5f9;
            border-radius: 12px;
            font-size: 15px;
            box-sizing: border-box;
            transition: 0.2s;
        }

        input:focus { outline: none; border-color: #3b82f6; background: white; }

        .grid { display: grid; grid-template-columns: 1fr 1fr; gap: 20px; }

        .checkbox-container {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 15px;
            margin: 20px 0;
        }

        .checkbox-item {
            display: flex;
            align-items: center;
            gap: 10px;
            background: #f8fafc;
            padding: 12px;
            border-radius: 12px;
            cursor: pointer;
            font-size: 14px;
            font-weight: 500;
        }

        .checkbox-item input { width: 18px; height: 18px; margin: 0; accent-color: #3b82f6; }

        .btn-submit {
            width: 100%;
            background: #3b82f6;
            color: white;
            padding: 14px;
            border: none;
            border-radius: 12px;
            font-size: 16px;
            font-weight: 600;
            cursor: pointer;
            transition: 0.2s;
        }

        .btn-submit:hover { background: #2563eb; transform: translateY(-1px); }

        .back-link { display: block; text-align: center; margin-top: 20px; color: #94a3b8; text-decoration: none; font-size: 14px; }
    </style>
</head>
<body>
    <div class="form-card">
        <h2>🏠 {{#if item.id}}Редагування{{else}}Новий об'єкт{{/if}}</h2>
        <form action="/houses/{{#if item.id}}edit/{{item.id}}{{else}}add{{/if}}" method="POST">
            <div class="form-group">
                <label>Вулиця та номер</label>
                <input type="text" name="street" value="{{item.street}}" required>
            </div>
            <div class="grid">
                <div class="form-group"><label>Площа (м²)</label><input type="number" step="0.1" name="house_area" value="{{item.house_area}}" required></div>
                <div class="form-group"><label>Ділянка (сот)</label><input type="number" step="0.1" name="plot_area" value="{{item.plot_area}}"></div>
            </div>
            <div class="grid">
                <div class="form-group"><label>Кімнат</label><input type="number" name="rooms_count" value="{{item.rooms_count}}" required></div>
                <div class="form-group"><label>Поверхів</label><input type="number" name="floors_count" value="{{item.floors_count}}" required></div>
            </div>
            <div class="form-group">
                <label>Колір фасаду</label>
                <input type="text" name="house_color" value="{{item.house_color}}">
            </div>
            <div class="checkbox-container">
                <label class="checkbox-item"><input type="checkbox" name="has_garage" {{#if item.has_garage}}checked{{/if}}> Гараж</label>
                <label class="checkbox-item"><input type="checkbox" name="is_renovated" {{#if item.is_renovated}}checked{{/if}}> Ремонт</label>
            </div>
            <div class="form-group">
                <label>Опис</label>
                <textarea name="extra_info" rows="3">{{item.extra_info}}</textarea>
            </div>
            <button type="submit" class="btn-submit">Зберегти об'єкт</button>
            <a href="/houses" class="back-link">← Назад до списку</a>
        </form>
    </div>
</body>
</html>