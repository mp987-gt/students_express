<button
style="background-color: rgb(254, 0, 178)">
    <a style="color:#ffffff" href="/product">
        GO BACK
    </a>
</button>
<form method="POST" action="{{action}}">
    <fieldset>
        <label>
            Barcode
            <input
                    name="barcode"
                    placeholder="Barcode"
                    
            />
        </label>
        <label>
            Name product
            <input
                    name="name"
                    placeholder="Name product"
                    
            />
        </label>
        <label>
            Price
            <input
                    name="price"
                    placeholder="Price"
                    
            />
        </label>
        <label>
            Quantity
            <input
                    name="quantity"
                    placeholder="quantity"
                    
            />
        </label>
    </fieldset>

    <input
            type="submit"
            value="SAVE"
    />
</form>