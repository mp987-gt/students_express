<button 
    style="background-color: rgb(242, 130, 208)">
    <a style="color:#ffffff" href="/">
        GO BACK
    </a>
</button>

<table>
    <thead>
    <tr>
        <th scope="col">ID</th>
        <th scope="col">name</th>
        <th scope="col">age</th>
        <th scope="col">country</th>
        <th scope="col">created at</th>
    </tr>
    </thead>
    <tbody>
    {{#each president}}
        <tr>
            <th scope="row">{{this.id}}</th>
            <td>{{this.name}}</td>
            <td>{{this.age}}</td>
            <td>{{this.country}}</td>          
            <td>{{this.created_at}}</td>
            
             <td><a style="color:rgb(21, 255, 0)" href="/president/update/{{this.id}}">Edit</a></td> 
                    <td><a style="color:rgb(255, 0, 0)" href="/president/delete/{{this.id}}">Delete</a></td>
                
        
    {{/each}}
    </tbody>
    <p><a style="color:rgb(229, 102, 168)" href="/president/create">ADD PRESIDENT</a></p>
</table>