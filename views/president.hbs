<style>
  
  :root {
    --gold: #c9a84c;
    --gold-light: #e8c97a;
    --dark: #0d0d0d;
    --dark3: #1c1c1c;
    --cream: #f5f0e8;
  }

  .page { max-width: 1000px; margin: 0 auto; padding: 3rem 2rem; font-family: 'Cormorant Garamond', serif; color: var(--cream); }
  .header { text-align: center; margin-bottom: 3rem; }
  .header::before, .header::after { content: ''; display: block; width: 60px; height: 2px; background: var(--gold); margin: 0 auto; }
  .header::before { margin-bottom: 1.5rem; }
  .header::after { margin-top: 1.5rem; }
  .header h1 { font-family: 'Playfair Display', serif; font-size: 3rem; font-weight: 900; letter-spacing: 6px; text-transform: uppercase; }
  .header h1 span { color: var(--gold); }
  .subtitle { font-size: 0.85rem; letter-spacing: 4px; text-transform: uppercase; color: rgba(201,168,76,0.6); margin-top: 0.75rem; }
  .top-bar { display: flex; justify-content: space-between; align-items: center; margin-bottom: 2rem; }
  .btn-back { display: inline-flex; align-items: center; gap: 8px; font-family: 'Cormorant Garamond', serif; font-size: 0.85rem; letter-spacing: 3px; text-transform: uppercase; color: var(--gold); text-decoration: none; border: 1px solid rgba(201,168,76,0.3); padding: 10px 20px; transition: all 0.3s; }
  .btn-back:hover { background: rgba(201,168,76,0.1); border-color: var(--gold); }
  .btn-add { font-family: 'Cormorant Garamond', serif; font-size: 0.85rem; letter-spacing: 3px; text-transform: uppercase; color: var(--dark); text-decoration: none; background: var(--gold); padding: 10px 24px; transition: all 0.3s; }
  .btn-add:hover { background: var(--gold-light); }
  .table-wrap { border: 1px solid rgba(201,168,76,0.2); overflow: hidden; }
  table { width: 100%; border-collapse: collapse; }
  thead tr { background: var(--dark3); border-bottom: 1px solid var(--gold); }
  thead th { font-family: 'Playfair Display', serif; font-size: 0.7rem; letter-spacing: 4px; text-transform: uppercase; color: var(--gold); padding: 18px 20px; text-align: left; font-weight: 400; }
  tbody tr { border-bottom: 1px solid rgba(201,168,76,0.08); transition: background 0.2s; }
  tbody tr:hover { background: rgba(201,168,76,0.04); }
  tbody th, tbody td { padding: 18px 20px; font-size: 1rem; font-weight: 300; color: var(--cream); text-align: left; }
  tbody th { font-family: 'Playfair Display', serif; color: rgba(197,168,100,0.5); font-size: 0.85rem; font-weight: 400; width: 50px; }
  .name-cell { font-family: 'Playfair Display', serif; font-size: 1.1rem; font-weight: 700; }
  .country-cell { font-style: italic; color: rgba(245,240,232,0.7); }
  .date-cell { font-size: 0.85rem; color: rgba(245,240,232,0.4); }
  .actions { display: flex; gap: 12px; align-items: center; }
  .btn-edit, .btn-delete { font-family: 'Cormorant Garamond', serif; font-size: 0.75rem; letter-spacing: 2px; text-transform: uppercase; text-decoration: none; padding: 6px 14px; border: 1px solid; transition: all 0.25s; }
  .btn-edit { color: var(--gold); border-color: rgba(201,168,76,0.3); }
  .btn-edit:hover { background: rgba(201,168,76,0.12); border-color: var(--gold); }
  .btn-delete { color: #c0392b; border-color: rgba(192,57,43,0.3); }
  .btn-delete:hover { background: rgba(192,57,43,0.1); border-color: #c0392b; }
  .divider { width: 1px; height: 14px; background: rgba(201,168,76,0.2); }
  .footer-line { margin-top: 2rem; text-align: center; font-size: 0.75rem; letter-spacing: 3px; text-transform: uppercase; color: rgba(201,168,76,0.25); }
</style>

<div class="page">
  <div class="header">
    <h1>Presi<span>dents</span></h1>
    <p class="subtitle">Hall of Leaders</p>
  </div>

  <div class="top-bar">
    <a href="/" class="btn-back">← Go Back</a>
    <a href="/president/create" class="btn-add">+ Add President</a>
  </div>

  <div class="table-wrap">
    <table>
      <thead>
        <tr>
          <th>ID</th>
          <th>Name</th>
          <th>Age</th>
          <th>Country</th>
          <th>Created At</th>
          <th></th>
        </tr>
      </thead>
      <tbody>
        {{#each president}}
        <tr>
          <th scope="row">{{this.id}}</th>
          <td class="name-cell">{{this.name}}</td>
          <td>{{this.age}}</td>
          <td class="country-cell">{{this.country}}</td>
          <td class="date-cell">{{this.created_at}}</td>
          <td>
            <div class="actions">
              <a href="/president/update/{{this.id}}" class="btn-edit">Edit</a>
              <div class="divider"></div>
              <a href="/president/delete/{{this.id}}" class="btn-delete">Delete</a>
            </div>
          </td>
        </tr>
        {{/each}}
      </tbody>
    </table>
  </div>

</div>