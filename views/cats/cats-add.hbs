<style>
  body, html {
    height: 100%;
    margin: 0;
    padding: 0;
    background-color: #ffffff; 
    color: #000000;
    font-family: 'Inter', 'Segoe UI', Roboto, sans-serif;
    display: flex;
    justify-content: center;
    align-items: center;
    overflow: hidden;
  }

  .form-container {
    background: #ffffff;
    border: 3px solid #000000; 
    width: 420px;
    padding: 20px;
    position: relative;
    box-shadow: 10px 10px 0px #000000; 
    box-sizing: border-box;
    left: 500px; 

  }

  h2 {
    font-size: 20px;
    font-weight: 900;
    text-transform: uppercase;
    margin: 0 0 15px 0;
    border-bottom: 2px solid #000;
    padding-bottom: 5px;
    letter-spacing: -1px;
    color: #000000;
  }

  .form-group {
    margin-bottom: 10px;
  }

  label {
    display: block;
    font-weight: 900;
    text-transform: uppercase;
    font-size: 10px;
    margin-bottom: 4px;
    color: #000000;
  }

  input[type="text"], 
  input[type="number"], 
  textarea,
  select {
    width: 100%;
    border: 2px solid #000;
    padding: 10px;
    background-color: #1a1f26; 
    color: #ffffff; 
    font-weight: 800;
    font-family: inherit;
    box-sizing: border-box;
    text-transform: uppercase;
    font-size: 12px;
  }

  input::placeholder, textarea::placeholder {
    color: #6c757d;
  }

  input:focus, textarea:focus, select:focus {
    outline: none;
    background-color: #252b36;
  }

  .row {
    display: flex;
    gap: 10px;
  }

  .row > div {
    flex: 1;
  }

  .checkbox-group {
    display: flex;
    align-items: center;
    gap: 8px;
    margin: 10px 0;
    font-weight: 900;
    font-size: 10px;
    text-transform: uppercase;
    color: #000000;
  }

  .checkbox-group input {
    width: 18px;
    height: 18px;
    accent-color: #1a1f26;
    cursor: pointer;
    margin: 0;
  }

  .btn-submit {
    width: 100%;
    background-color: #000;
    color: #fff;
    border: 2px solid #000;
    padding: 12px;
    font-weight: 900;
    font-size: 14px;
    text-transform: uppercase;
    cursor: pointer;
    transition: all 0.2s ease;
    margin-top: 5px;
  }

  .btn-submit:hover {
    background-color: #ffffff;
    color: #000;
  }

  .btn-back {
    display: block;
    text-align: center;
    margin-top: 15px;
    color: #000;
    text-decoration: none;
    font-weight: 900;
    font-size: 10px;
    text-transform: uppercase;
    text-decoration: underline;
  }
</style>

<div class="form-container">
  <h2>{{#if isEdit}}Edit Cat{{else}}Register New Cat{{/if}}</h2>

  <form action="{{#if isEdit}}/cats/update{{else}}/cats/add{{/if}}" method="POST">
    
    <input type="hidden" name="username" value="{{username}}">
    
    {{#if isEdit}}
      <input type="hidden" name="cat_id" value="{{cat.id}}">
    {{/if}}

    <div class="row">
      <div class="form-group">
        <label>Cat Name</label>
        <input type="text" name="name" placeholder="MEOWTH" value="{{cat.name}}" required>
      </div>
      <div class="form-group">
        <label>Breed</label>
        <input type="text" name="breed" placeholder="MIXED" value="{{cat.breed}}">
      </div>
    </div>

    <div class="row">
      <div class="form-group">
        <label>Age (Y)</label>
        <input type="number" name="age_years" placeholder="0" value="{{cat.age_years}}">
      </div>
      <div class="form-group">
        <label>Weight (KG)</label>
        <input type="number" step="0.1" name="weight_kg" placeholder="0.0" value="{{cat.weight_kg}}">
      </div>
    </div>

    <div class="row">
      <div class="form-group">
        <label>Favorite Food</label>
        <input type="text" name="favorite_food" placeholder="TUNA" value="{{cat.favorite_food}}">
      </div>
      <div class="form-group">
        <label>Owner Contact</label>
        <input type="text" name="owner_contact" placeholder="EMAIL/PHONE" value="{{cat.owner_contact}}">
      </div>
    </div>

    <div class="checkbox-group">
      <input type="checkbox" name="has_microchip" id="chip" {{#if cat.has_microchip}}checked{{/if}}>
      <label for="chip">Has Microchip</label>
    </div>

    <div class="form-group">
      <label>Character Notes</label>
      <textarea name="character_notes" rows="2" placeholder="NOTES...">{{cat.character_notes}}</textarea>
    </div>

    <button type="submit" class="btn-submit">
      {{#if isEdit}}Save Changes{{else}}Add to Database{{/if}}
    </button>
    
    <a href="/cats/profile?user={{username}}" class="btn-back">Cancel and Go Back</a>
  </form>
</div>