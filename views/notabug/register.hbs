<link rel="stylesheet" href="/stylesheets/notabug.css">

<div class="page-wrap {{chaosBodyClass}}">
  <nav class="topbar">
    <div class="topbar-logo">
      <span class="bug-icon">🐞</span>
      <span class="glitch-text" data-text="NotABug">NotABug</span>
    </div>

    <div class="topbar-nav">
      <a href="/notabug" class="nav-link">Dashboard</a>
      {{#if user}}
        <a href="/notabug/profile/{{user.username}}" class="nav-link">{{user.username}}</a>
        <a href="/notabug/logout" class="nav-link">Logout</a>
      {{else}}
        <a href="/notabug/login" class="nav-link">Login</a>
      {{/if}}
    </div>

    <div class="topbar-stats">
      <div class="stat-chip chaos {{globalChaosClass}}">
        <span>🔥 Chaos</span>
        <span class="val">{{chaosLevel}}%</span>
      </div>
      <div class="stat-chip">
        <span>🧠 Sanity</span>
        <span class="val">{{globalSanity}}%</span>
      </div>
    </div>
  </nav>

  <div class="main" style="max-width:600px;">
    <div style="margin-bottom:20px;">
      <a href="/notabug" class="back-link">← Back to Dashboard</a>
    </div>

    <div class="section-header">
      <div class="section-label">// HUNTER REGISTRATION</div>
      <div class="section-title">Register as Bug Hunter</div>
      <div class="section-sub">Join the hunt. Your sanity starts at 100. Good luck.</div>
    </div>

    {{#if error}}
    <div class="card" style="border-color: var(--danger); margin-bottom: 20px;">
      <div style="padding: 16px 20px; color: var(--danger);">
        <strong>⚠ REGISTRATION FAILED</strong><br>
        {{error}}
      </div>
    </div>
    {{/if}}

    <div class="card">
      <div class="form-card">
        <form method="POST" action="/notabug/register">
          <div class="form-grid">
            <div class="form-field full">
              <label for="username">Username</label>
              <input 
                type="text" 
                id="username" 
                name="username" 
                required 
                placeholder="alphanumeric, -, _ only"
                minlength="3" 
                maxlength="30"
                pattern="[a-zA-Z0-9_-]+"
              >
              <small style="color: var(--text-muted); margin-top: 4px; display: block;">3-30 characters, alphanumeric with - and _</small>
            </div>

            <div class="form-field full">
              <label for="email">Email (optional)</label>
              <input 
                type="email" 
                id="email" 
                name="email" 
                placeholder="your@email.com"
                maxlength="255"
              >
            </div>

            <div class="form-field full">
              <label for="password">Password</label>
              <input 
                type="password" 
                id="password" 
                name="password" 
                required 
                placeholder="••••••"
                minlength="6" 
                maxlength="100"
              >
              <small style="color: var(--text-muted); margin-top: 4px; display: block;">6-100 characters</small>
            </div>

            <div class="form-field full">
              <label for="confirmPassword">Confirm Password</label>
              <input 
                type="password" 
                id="confirmPassword" 
                name="confirmPassword" 
                required 
                placeholder="••••••"
                minlength="6" 
                maxlength="100"
              >
            </div>
          </div>

          <div class="form-actions">
            <a href="/notabug" class="btn btn-ghost">Cancel</a>
            <button type="submit" class="btn btn-primary" style="width: auto;">Register</button>
          </div>
        </form>

        <div style="margin-top: 20px; padding-top: 20px; border-top: 1px solid var(--border); text-align: center;">
          <small style="color: var(--text-muted);">Already a hunter? <a href="/notabug/login" style="color: var(--accent); text-decoration: underline;">Login here</a></small>
        </div>
      </div>
    </div>
  </div>
</div>

<style>
  .form-grid {
    display: grid;
    gap: 16px;
  }

  .form-field {
    display: flex;
    flex-direction: column;
  }

  .form-field.full {
    grid-column: 1 / -1;
  }

  .form-field label {
    font-size: 12px;
    font-weight: 600;
    color: var(--text-dim);
    margin-bottom: 8px;
    text-transform: uppercase;
    letter-spacing: 0.5px;
  }

  .form-field input {
    padding: 10px 12px;
    border: 1px solid var(--border);
    background: var(--bg);
    color: var(--text);
    font-family: 'Space Mono', monospace;
    font-size: 13px;
    border-radius: 3px;
    transition: all 0.2s;
  }

  .form-field input:focus {
    outline: none;
    border-color: var(--accent);
    box-shadow: 0 0 0 2px rgba(0, 229, 255, 0.1);
  }

  .form-actions {
    display: flex;
    gap: 12px;
    margin-top: 20px;
    justify-content: flex-start;
  }

  .btn {
    padding: 10px 16px;
    border: 1px solid var(--border);
    background: transparent;
    color: var(--text);
    cursor: pointer;
    font-family: 'Space Mono', monospace;
    font-size: 11px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    border-radius: 3px;
    transition: all 0.2s;
  }

  .btn:hover {
    border-color: var(--accent);
    color: var(--accent);
  }

  .btn-primary {
    background: var(--accent);
    color: var(--bg);
    border-color: var(--accent);
  }

  .btn-primary:hover {
    background: transparent;
    color: var(--accent);
  }

  .btn-ghost {
    color: var(--text-muted);
  }

  .btn-ghost:hover {
    color: var(--text);
  }
</style>
