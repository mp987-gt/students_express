<!--view table of students-->
<table>
    <thead>
    <tr>
        <th scope="col">ID</th>
        <th scope="col">First Name</th>
        <th scope="col">Last Name</th>
        <th scope="col">created_at</th>
    </tr>
    </thead>
    <tbody>
    {{#each weapons}}
        <tr>
            <th scope="row">{{this.id}}</th>
            <td>{{this.firstname}}</td>
            <td>{{this.lastname}}</td>
            <td>{{this.created_at}}</td>
        </tr>
    {{/each}}
    </tbody>
</table>